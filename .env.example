# =============================================================================
# TOO HUMBLE - Environment Variables Template
# Copy to .env and fill in your real values. NEVER commit .env to git.
# =============================================================================

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Daraja M-Pesa (required for payments)
EXPO_PUBLIC_DARAJA_CONSUMER_KEY=your-daraja-consumer-key
EXPO_PUBLIC_DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
EXPO_PUBLIC_DARAJA_SHORTCODE=174379
EXPO_PUBLIC_DARAJA_PASSKEY=your-daraja-passkey
EXPO_PUBLIC_DARAJA_CALLBACK_URL=https://your-api-domain.com/api/mpesa-callback

# PayPal (required for global payments)
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
