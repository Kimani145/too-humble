{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["https://deno.land/x/types/index.d.ts"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
