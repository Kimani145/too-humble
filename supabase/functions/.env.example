# =============================================================================
# TOO HUMBLE - Supabase Edge Functions Environment Variables
# Set these via `supabase secrets set` CLI or the Supabase Dashboard
# NEVER commit real values to version control. This file is a template.
# =============================================================================

# Supabase (auto-set when deployed via CLI)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Daraja / M-Pesa (Safaricom)
# DARAJA_SANDBOX: set to "true" for sandbox, "false" for production
DARAJA_CONSUMER_KEY=YOUR_DARAJA_CONSUMER_KEY
DARAJA_CONSUMER_SECRET=YOUR_DARAJA_CONSUMER_SECRET
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=YOUR_DARAJA_PASSKEY
DARAJA_CALLBACK_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/mpesa-callback
DARAJA_SANDBOX=true

# PayPal
# PAYPAL_SANDBOX: set to "true" for sandbox, "false" for production
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID
PAYPAL_SANDBOX=true

# =============================================================================
# Deployment Instructions:
#
# 1. Copy this template: cp .env.example .env.local (and add to .gitignore)
# 2. Fill in real values in .env.local
# 3. Deploy secrets to Supabase:
#      supabase secrets set --env-file .env.local
# 4. Deploy Edge Functions:
#      supabase functions deploy mpesa-initiate
#      supabase functions deploy mpesa-callback
#      supabase functions deploy paypal-create-order
#      supabase functions deploy paypal-webhook
# 5. Register mpesa-callback URL in Daraja portal
# 6. Register paypal-webhook URL in PayPal Developer Dashboard
# =============================================================================
